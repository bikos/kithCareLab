{
  "name": "kithcare",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export -p web",
    "build:local": "eas build --platform android --profile production --local",
    "build:production": "eas build --platform android --profile production",
    "build:deploy": "eas build --platform android --profile production --auto-submit",
    "build:apk": "eas build --platform android --profile preview --local",
    "build:ios-local": "eas build --platform ios --profile production --local",
    "build:ios-prod": "eas build --platform ios --profile production",
    "build:ios-deploy": "eas build --platform ios --profile production --auto-submit",
    "deploy:web": "npm run build:web && npx netlify deploy --prod --dir=dist"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@lottiefiles/dotlottie-react": "^0.13.5",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@supabase/supabase-js": "^2.84.0",
    "base64-arraybuffer": "^1.0.2",
    "date-fns": "^4.1.0",
    "expo": "~54.0.27",
    "expo-constants": "~18.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "^19.0.19",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.9",
    "expo-in-app-updates": "^0.9.0",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-notifications": "~0.32.14",
    "expo-router": "~6.0.17",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "lottie-react-native": "~7.3.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-paper": "^5.14.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.0",
    "zustand": "^5.0.8"
  },
  "private": true,
  "devDependencies": {
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  }
}